// Production version of the photo-analysis pipeline.
// Three chained stages: (1) Gemini vision read, (2) deterministic safety
// verification, (3) Gemini reasoning call that turns the verified attributes
// into a sell/donate/recycle recommendation, price, and drafted listing.
// Client-facing errors are clean and generic; failure detail is logged
// server-side only — never returned in the response body.

// ---------------- Stage 1: vision read ----------------
// One Gemini call that looks at the photo and returns raw structured attributes.

// ---------------- Stage 2: deterministic safety verification ----------------
// Runs AFTER Stage 1, with no model call at all — a fixed, auditable table of
// known hazard language per category, cross-checked against Stage 1's own
// defect flags. Escalates anything that looks like a safety issue but got
// returned as a mere cosmetic "defect." This exists because a single AI call
// can be inconsistent about where it draws the line between "cosmetic" and
// "unsafe" — a deterministic second pass gives a consistent safety floor that
// doesn't depend on model mood, and doesn't cost a second API call.
const HAZARD_LEXICON = {
  Electronics: ["frayed cord", "exposed wire", "cracked casing", "burn mark", "swollen battery", "damaged plug", "sparking"],
  Kids: ["expired", "recalled", "cracked", "broken buckle", "missing strap", "choking", "loose part"],
  Furniture: ["structural crack", "unstable", "broken leg", "sharp edge", "wobbly frame"],
  Clothing: ["mold", "chemical smell"],
  Other: []
};

function verifySafety(parsed, category) {
  const lexicon = HAZARD_LEXICON[category] || [];
  const remainingDefects = [];
  const escalations = [];

  (parsed.defect_flags || []).forEach((flag) => {
    const flagLower = flag.toLowerCase();
    const matchedTerm = lexicon.find((term) => flagLower.includes(term));
    if (matchedTerm) {
      escalations.push({ original: flag, matchedTerm, category });
    } else {
      remainingDefects.push(flag);
    }
  });

  return {
    ...parsed,
    defect_flags: remainingDefects,
    hazard_flags: [...(parsed.hazard_flags || []), ...escalations.map((e) => e.original)],
    escalations,
    safety_check: escalations.length > 0 ? "escalated" : "passed"
  };
}

// ---------------- Shared Gemini caller ----------------
// Hard timeout so a slow/stuck call can't hang a request indefinitely, plus
// one retry on transient failures (timeouts, 429s, brief 5xx blips). A demo
// or a real buyer only gets one shot at a first impression — a flaky network
// moment shouldn't be the difference between "working" and "broken."
const GEMINI_TIMEOUT_MS = 15000;

async function callGeminiOnce(parts) {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), GEMINI_TIMEOUT_MS);

  try {
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key=${process.env.GEMINI_API_KEY}`,
      {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ contents: [{ parts }] }),
        signal: controller.signal
      }
    );
    const rawBody = await response.text();
    if (!response.ok) {
      const err = new Error(`Gemini API returned ${response.status}`);
      err.status = response.status;
      err.detail = rawBody.slice(0, 500);
      throw err;
    }
    const data = JSON.parse(rawBody);
    const text = data.candidates?.[0]?.content?.parts?.[0]?.text || "";
    return JSON.parse(text.replace(/```json|```/g, "").trim());
  } finally {
    clearTimeout(timeout);
  }
}

async function callGemini(parts) {
  try {
    return await callGeminiOnce(parts);
  } catch (err) {
    const transient = err.name === "AbortError" || err.status === 429 || (err.status && err.status >= 500);
    if (!transient) throw err;
    console.warn("Gemini call failed, retrying once:", err.status || err.name, err.detail || err.message);
    return await callGeminiOnce(parts);
  }
}

// ---------------- Stage 3: reasoning call, chained from Stage 1+2's output ----------------
// A second, text-only model call — no image, just the verified attributes from
// stages 1 and 2 passed in as input. This is a genuine second reasoning step,
// not a bigger prompt on the first call: it explicitly receives the safety-
// verification result AND the condition tier, and is instructed to let both
// change the recommendation. A safety hazard pushes toward "recycle" — and so
// does an item that's simply too worn for resale or donation, even with zero
// safety concerns. That second path is what actually makes "recycle" a real,
// reachable outcome instead of a hazard-only edge case.
async function recommendNextSteps(verified) {
  const prompt = `You are helping decide what should happen to a used item on a resale/donation marketplace. You've already been given verified attributes below — the hazard flags have already been through a separate safety check, so treat them as confirmed, not speculative.

Item: ${verified.item_name}
Material: ${verified.material}
Category: ${verified.category}
Condition: ${verified.condition}
Defects: ${verified.defect_flags.length ? verified.defect_flags.join("; ") : "none"}
Safety-verified hazards: ${verified.hazard_flags.length ? verified.hazard_flags.join("; ") : "none"}

Return ONLY a JSON object (no other text, no markdown fences) with exactly this shape:
{
  "recommended_action": "one of: sell, donate, recycle",
  "recommendation_reason": "one short sentence, explicitly referencing the condition and any hazards",
  "suggested_price_sar": integer (0 if recommended_action is donate or recycle),
  "price_reasoning": "one short sentence explaining the estimate based on category and condition",
  "drafted_description": "a 2-3 sentence seller-style listing description, ready to post as-is (empty string if recommended_action is recycle)"
}

Rules, in priority order:
1. If there are any safety-verified hazards, "recycle" — explain the hazard directly in recommendation_reason.
2. If condition is "Poor" (too worn, damaged, or non-functional to sell or donate) with no hazards, "recycle" — explain in recommendation_reason why it's unsuitable for resale or donation, not just that it's damaged.
3. If condition is "Fair" with no hazards, "donate" is usually more appropriate than "sell" for low resale-value categories.
4. Only recommend "sell" when condition is "Good" or "Like new" and there are no hazards.`;

  return callGemini([{ text: prompt }]);
}

export default async function handler(req, res) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Method not allowed" });
  }

  const { image, mediaType } = req.body || {};
  if (!image || !mediaType) {
    return res.status(400).json({ error: "Missing image or mediaType" });
  }

  if (!process.env.GEMINI_API_KEY) {
    console.error("GEMINI_API_KEY is not set on the server");
    return res.status(500).json({ error: "Photo analysis is temporarily unavailable. Please try again shortly." });
  }

  const visionPrompt = `Look at this photo of a used household or personal item that someone wants to sell, donate, or recycle on a second-hand marketplace.

Return ONLY a JSON object (no other text, no markdown fences) with exactly this shape:
{
  "item_name": "short name of the item",
  "material": "primary material, e.g. stainless steel, cotton, wood",
  "category": "one of: Electronics, Furniture, Clothing, Kids, Other",
  "condition": "one of: Like new, Good, Fair, Poor",
  "defect_flags": ["short phrase for each visible cosmetic or functional defect, empty array if none"],
  "hazard_flags": ["short phrase for each visible safety concern such as frayed cords, cracks, corrosion, or anything that looks recalled or expired, empty array if none"]
}

Use "Poor" only when the item is too worn, damaged, or non-functional to reasonably sell or donate as-is.`;

  // ---- Stage 1: vision read ----
  let parsed;
  try {
    parsed = await callGemini([
      { text: visionPrompt },
      { inline_data: { mime_type: mediaType, data: image } }
    ]);
  } catch (err) {
    console.error("Vision stage failed:", err.status || "", err.detail || err.message);
    return res.status(502).json({ error: "We couldn't read that photo. Please try a clearer photo or try again in a moment." });
  }

  // ---- Stage 2: deterministic safety verification (no model call) ----
  const verified = verifySafety(parsed, parsed.category || "Other");

  // ---- Stage 3: reasoning call chained from stages 1+2 ----
  try {
    const recommendation = await recommendNextSteps(verified);
    return res.status(200).json({ ...verified, ...recommendation });
  } catch (err) {
    // If the reasoning stage fails, still return the verified Stage 1+2 result
    // rather than failing the whole request — partial results beat none.
    console.error("Stage 3 (recommendation) failed:", err.status || "", err.detail || err.message);
    return res.status(200).json({ ...verified, recommendation_stage_failed: true });
  }
}
